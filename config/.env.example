# ContentPilot — Environment Variables
# Copy to .env and fill in your values

# === REQUIRED ===
BLOG_DOMAIN=yourblog.com
BLOG_ID=your_blog_id_here

# === AI Provider (pilih salah satu) ===
# OpenAI
# OPENAI_API_KEY=sk-...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Ollama (local, tidak perlu API key)

# === OPTIONAL ===
# TELEGRAM_BOT_TOKEN=***
# TELEGRAM_CHAT_ID=
